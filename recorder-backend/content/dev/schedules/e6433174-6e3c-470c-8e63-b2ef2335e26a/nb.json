        },
        "body1": {
          "fi": "Mitä someja käytät?",
          "nb": "Hvilke sosiale medier bruker du?"
        },
        "body2": {
          "fi": "Kun olet valmis puhumaan, paina Äänitä.",
          "nb": "Når du er klar til å snakke, trykk på Ta opp."
        },
