        "body1": {
          "fi": "Jo pelkkä rajaus voi vaikuttaa kuvaan paljon.",
          "nb": "Jo pelkkä rajaus voi vaikuttaa kuvaan paljon."
        },
        "body2": {
          "fi": "Paina Äänitä, niin näet kolme kuvaa. Mitä näet kuvassa ensin – entä sitten?",
