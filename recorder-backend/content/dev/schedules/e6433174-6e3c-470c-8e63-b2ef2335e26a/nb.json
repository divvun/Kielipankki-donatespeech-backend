      },
      "isRecording": true,
      "recording": {
        "title": {
          "fi": "Harjoitellaan ensin",
          "nb": "Harjoitellaan ensin"
        },
        "body1": {
          "fi": "Kerro, missä someissa olet.",
          "nb": "Fortell hvilke sosiale medier du er på."
        },
        "body2": {
          "fi": "Kun olet vastannut, paina Lopeta äänitys.",
          "nb": "Når du har svart, trykk på Stopp opptak."
        },
