          "fi": "Valehtelevat kuvat",
          "nb": "Valehtelevat kuvat"
        },
        "body1": {
          "fi": "Kerro, mistä huomaat tai päättelet väärennökset?",
          "nb": "Fortell hvordan du legger merke til eller slutter deg til forfalskningene?"
        },
        "body2": {
          "fi": "Video kestää 40 sekuntia.",
          "nb": "Video kestää 40 sekuntia."
        },
        "url": "1-50675687"
      },
      "finish": {
        "title": {
          "fi": "Tarkkaa työtä",
          "nb": "Tarkkaa työtä"
        },
        "body1": {
          "fi": "Joskus kuvat on käsitelty niin taitavasti, että ammattilainenkin menee vipuun.",
          "nb": "Joskus kuvat on käsitelty niin taitavasti, että ammattilainenkin menee vipuun."
        },
        "body2": {
          "fi": "Jatketaan vielä hetki kuvien kanssa.",
          "nb": "Jatketaan vielä hetki kuvien kanssa."
