        },
        "finish": {
          "title": "Mainiota!",
          "body1": "Olet päässyt kunnolla rupattelun vauhtiin.",
          "body2": "Lahjoittamasi puheaika näkyy ylhäällä oikealla ja hyvältä näyttää!",
          "url": "https://images.cdn.yle.fi/image/upload/w_1198,h_674,f_auto,fl_lossy,q_auto:eco/39-6756965ebd088d7d529.jpg"
        }
