        "start": {
          "title": "Min dialektbakgrunn",
          "body1": "Suomen kielen puhepankkiin on tosi tärkeätä saada mukaan kaikenlaista suomea. Kerro, miltä alueelta murteesi tai puhetapasi tulee.",
          "body2": "Jeg minner om at du finner mer informasjon om personvern i hovedmenyen.",
          "url": "1-50526448"
        },
        "isRecording": false
      },
