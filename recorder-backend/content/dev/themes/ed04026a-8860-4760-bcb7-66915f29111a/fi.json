        "typeId": "image/jpeg",
        "start": {
          "title": "Kysy suosikiltasi",
          "body1": "Sitten eteenpäin! Olet voittanut tapaamisen suosikkiurheilijasi kanssa.",
          "body2": "Nyt voit kysyä häneltä aivan kaikki mielessäsi olevat kysymykset.",
