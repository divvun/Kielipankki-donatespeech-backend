        },
        "isRecording": true,
        "recording": {
          "title": "Kysy suosikiltasi",
          "body1": "Kysele rohkeasti – olipa idolisi joku näistä kolmesta tai joku muu!",
          "body2": "(Vastaukset joudut kuvittelemaan itse.)",
          "url": "https://images.cdn.yle.fi/image/upload/w_1198,h_674,f_auto,fl_lossy,q_auto:eco/39-7226315f6c53f1b2778.jpg"
        },
        "finish": {
          "title": "Hienoa!",
          "body1": "Mukavaa, jos oma taustasi tai murteesi kuului puheessa.",
          "body2": "Tähän puhepankkiin on tärkeätä saada mukaan aivan kaikenlaista suomea. Auta siis tutkijoita ja kerro itsestäsi yksi taustatieto.",
          "url": "https://images.cdn.yle.fi/image/upload/w_1198,h_674,f_auto,fl_lossy,q_auto:eco/39-7226905f6c659661647.jpg"
        }
