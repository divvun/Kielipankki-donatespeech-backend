        "isRecording": true,
        "recording": {
          "title": "Alkulämmittely",
          "body1": "Kun olet valmis, paina Lopeta äänitys.",
          "body2": "",
          "url": "https://images.cdn.yle.fi/image/upload/w_1198,h_674,f_auto,fl_lossy,q_auto:eco/39-7226605f6c5b8c492d1.jpg"
        },
        "finish": {
          "title": "Hyvin meni!",
          "body1": "Pieni muistutus ennen kuin jatketaan: Puhettasi pääsevät kuulemaan vain tutkijat ja tekoälyn kehittäjät.",
          "body2": "Tietosuojasta voit lukea lisää aloitussivulta.",
          "url": "https://images.cdn.yle.fi/image/upload/w_1198,h_674,f_auto,fl_lossy,q_auto:eco/39-7226595f6c5b8c28946.jpg"
        }
