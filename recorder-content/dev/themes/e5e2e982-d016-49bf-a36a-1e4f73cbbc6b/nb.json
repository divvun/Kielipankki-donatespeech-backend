        "typeId": "video/mp4",
        "start": {
          "title": "Ensin esileikki",
          "body1": "Snart får du utløp for presset. Men la oss starte med en bildegåte.",
          "body2": "Du ser snart to bilder. Finn tre forskjeller i bildene.",
          "url": "1-50635290"
        },
        "isRecording": false
      },
      {
        "itemId": "d1e54243-2f0b-4118-9bd6-78c45ad805b2",
        "kind": "media",
        "itemType": "image",
        "typeId": "image/jpeg",
        "start": {
          "title": "Etsi erot",
          "body1": "Når du har funnet forskjellene, trykk Ta opp og fortell om dem med dine egne ord.",
          "body2": "Juttele puhekielellä! Takeltelu ja hymähtely ovat sallittuja.",
          "url": "https://images.cdn.yle.fi/image/upload/w_1198,h_674,f_auto,fl_lossy,q_auto:eco/39-7207925f649976ee48d.jpg"
        },
        "isRecording": true,
        "finish": {
          "title": "Flott! Vi fortsetter snart!",
          "body1": "Tiesitkö, että puhelahjoitus on salatumpi kuin spermapankki? Lahjoittaja jää aina tuntemattomaksi.",
          "body2": "Bare forskere og AI-utviklere kan høre talen din. Les mer om personvern fra startsiden.",
          "url": "https://images.cdn.yle.fi/image/upload/w_1198,h_674,f_auto,fl_lossy,q_auto:eco/39-7237365f71a4ea965f4.jpg"
        }
      },
