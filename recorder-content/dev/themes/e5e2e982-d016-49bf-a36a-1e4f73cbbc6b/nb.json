        "kind": "media",
        "itemType": "yle-video",
        "typeId": "video/mp4",
        "start": {
          "title": "Terveisiä perseestä!",
          "body1": "Nå får du klage! Hva har irritert deg i det siste? Korona, politikere eller naboen din?",
          "body2": "Fortell det til AI-en. Den snakker ikke videre.",
          "url": "1-50635293"
        },
        "isRecording": false
      },
